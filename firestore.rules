rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    match /wishes/{wishId} {
      allow read: if true; // Publicly readable
      allow create: if isValidId(wishId) 
        && incoming().name is string && incoming().name.size() > 0 && incoming().name.size() <= 50
        && incoming().content is string && incoming().content.size() > 0 && incoming().content.size() <= 300
        && incoming().createdAt == request.time;
    }
  }
}
